# Schwab API credentials — register at developer.schwab.com
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# Email delivery (Gmail SMTP)
GMAIL_SENDER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
GMAIL_RECIPIENT=your_email@gmail.com

# Path to messages-to-midnight scan.py (clone that repo separately)
# See: https://base.societus.club/societus/messages-to-midnight
SCAN_SCRIPT_PATH=/path/to/messages-to-midnight/scripts/scan.py

# SearXNG endpoints — used by opportunity_scanner.py and scan.py
# Public instance (primary); leave blank if only using local Docker
SEARXNG_URL=https://your-searxng-instance.example.com
# Local Docker fallback (default: http://localhost:8080)
SEARXNG_INTERNAL_URL=http://localhost:8080
